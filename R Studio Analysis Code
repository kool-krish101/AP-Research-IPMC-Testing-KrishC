# 2. Data Import and Merging

```{r import-data}
# Read all CSV files
master_sheet <- read.csv("MasterSheet.csv", stringsAsFactors = FALSE)
metadata <- read.csv("MetaData.csv", stringsAsFactors = FALSE)
performance <- read.csv("PerformanceMetrics.csv", stringsAsFactors = FALSE)
fabrication <- read.csv("FabricationSpeifications.csv", stringsAsFactors = FALSE)
testing <- read.csv("TestingConditions.csv", stringsAsFactors = FALSE)

# Create summary table
data_summary <- data.frame(
  Dataset = c("Master Sheet", "Metadata", "Performance", "Fabrication", "Testing"),
  Rows = c(nrow(master_sheet), nrow(metadata), nrow(performance), 
           nrow(fabrication), nrow(testing)),
  Columns = c(ncol(master_sheet), ncol(metadata), ncol(performance), 
              ncol(fabrication), ncol(testing))
)

kable(data_summary, caption = "Table 1: Imported Datasets Summary") %>%
  kable_styling(bootstrap_options = c("striped", "hover", "condensed"), 
                full_width = FALSE, position = "left")
```

```{r merge-data}
# Merge all datasets
data <- master_sheet %>%
  left_join(metadata %>% select(study_id, sample_size, doi_or_url, inclusion_justification), 
            by = "study_id") %>%
  left_join(performance %>% select(study_id, response_time_ms, strain_percent), 
            by = "study_id") %>%
  left_join(fabrication %>% select(study_id, surface_roughening, plating_duration_min, 
                                   ion_exchange_ion), 
            by = "study_id") %>%
  left_join(testing %>% select(study_id, humidity_percent, specimen_length_mm, 
                               specimen_width_mm, loading_condition), 
            by = "study_id")
```

