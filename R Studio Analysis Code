# 8. Pairwise Comparisons

```{r pairwise, fig.width=11, fig.height=7, fig.cap="Figure 2: Statistical Significance of Pairwise Comparisons"}
electrodes <- unique(data$electrode_material)
pairwise_results <- data.frame()

for(i in 1:(length(electrodes)-1)) {
  for(j in (i+1):length(electrodes)) {
    group1 <- data %>% filter(electrode_material == electrodes[i])
    group2 <- data %>% filter(electrode_material == electrodes[j])
    
    t_disp <- t.test(group1$displacement_mm, group2$displacement_mm)
    t_force <- t.test(group1$force_mN, group2$force_mN)
    t_cycles <- t.test(group1$cycles_to_failure, group2$cycles_to_failure)
    
    pairwise_results <- rbind(pairwise_results, data.frame(
      Comparison = paste(electrodes[i], "vs", electrodes[j]),
      `Δ Displacement` = sprintf("%.2f", t_disp$estimate[1] - t_disp$estimate[2]),
      `p (Disp)` = sprintf("%.4f", t_disp$p.value),
      `Sig (Disp)` = ifelse(t_disp$p.value < 0.05, "✓", ""),
      `Δ Force` = sprintf("%.2f", t_force$estimate[1] - t_force$estimate[2]),
      `p (Force)` = sprintf("%.4f", t_force$p.value),
      `Sig (Force)` = ifelse(t_force$p.value < 0.05, "✓", ""),
      `Δ Cycles` = sprintf("%.0f", t_cycles$estimate[1] - t_cycles$estimate[2]),
      `p (Cycles)` = sprintf("%.4f", t_cycles$p.value),
      `Sig (Cycles)` = ifelse(t_cycles$p.value < 0.05, "✓", ""),
      stringsAsFactors = FALSE,
      check.names = FALSE
    ))
  }
}

kable(pairwise_results, 
      caption = "Table 7: Pairwise T-Test Comparisons Between Electrode Materials",
      align = c('l', rep('c', 9))) %>%
  kable_styling(bootstrap_options = c("striped", "hover"), 
                full_width = FALSE, font_size = 11) %>%
  row_spec(0, bold = TRUE, background = "#3498DB", color = "white") %>%
  column_spec(1, bold = TRUE) %>%
  column_spec(c(4, 7, 10), background = "#E8F4F8") %>%
  footnote(general = "✓ indicates p < 0.05 (statistically significant)")

# Visualization
pairwise_long <- pairwise_results %>%
  select(Comparison, `p (Disp)`, `p (Force)`, `p (Cycles)`) %>%
  mutate(across(starts_with("p"), as.numeric)) %>%
  pivot_longer(cols = starts_with("p"),
               names_to = "metric",
               values_to = "p_value") %>%
  mutate(metric = recode(metric,
                         `p (Disp)` = "Displacement",
                         `p (Force)` = "Force",
                         `p (Cycles)` = "Durability"),
         significant = ifelse(p_value < 0.05, "Significant (p < 0.05)", "Not Significant"))

ggplot(pairwise_long, aes(x = reorder(Comparison, -p_value), 
                          y = -log10(p_value), 
                          fill = significant)) +
  geom_col() +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", 
             color = "red", size = 1) +
  facet_wrap(~metric, ncol = 1, scales = "free_y") +
  coord_flip() +
  labs(title = "Statistical Significance of Pairwise Comparisons",
       subtitle = "Red dashed line indicates p = 0.05 threshold; higher bars = more significant",
       x = "Electrode Comparison",
       y = "-log₁₀(p-value)",
       fill = "Significance") +
  theme_minimal(base_size = 11) +
  scale_fill_manual(values = c("Significant (p < 0.05)" = "#27AE60", 
                               "Not Significant" = "#E74C3C")) +
  theme(legend.position = "bottom",
        strip.text = element_text(face = "bold", size = 12),
        panel.grid.major.y = element_blank())
