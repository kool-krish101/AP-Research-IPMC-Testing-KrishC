# 6. Meta-Analysis Results

## 6.1 Overall Pooled Effect

```{r meta-overall}
meta_overall <- rma(yi = displacement_mm, 
                    vi = displacement_sd^2 / sample_size,
                    data = data,
                    method = "REML")

# Create results table
overall_results <- data.frame(
  Parameter = "Overall Mean Displacement",
  Estimate = sprintf("%.3f", meta_overall$beta),
  `SE` = sprintf("%.3f", meta_overall$se),
  `95% CI` = sprintf("[%.3f, %.3f]", meta_overall$ci.lb, meta_overall$ci.ub),
  `p-value` = sprintf("%.4f", meta_overall$pval),
  check.names = FALSE
)

kable(overall_results, 
      caption = "Table 3: Overall Pooled Effect for Displacement",
      align = 'c') %>%
  kable_styling(bootstrap_options = c("striped", "hover"), 
                full_width = FALSE, position = "center")
```

## 6.2 Displacement by Electrode Material

```{r meta-displacement}
meta_displacement <- rma(yi = displacement_mm, 
                         vi = displacement_sd^2 / sample_size,
                         mods = ~ electrode_material,
                         data = data,
                         method = "REML")

# Format results
disp_results <- data.frame(
  Coefficient = names(coef(meta_displacement)),
  Estimate = sprintf("%.3f", coef(meta_displacement)),
  `Std Error` = sprintf("%.3f", meta_displacement$se),
  `95% CI Lower` = sprintf("%.3f", meta_displacement$ci.lb),
  `95% CI Upper` = sprintf("%.3f", meta_displacement$ci.ub),
  `p-value` = sprintf("%.4f", meta_displacement$pval),
  Significance = ifelse(meta_displacement$pval < 0.001, "***",
                       ifelse(meta_displacement$pval < 0.01, "**",
                             ifelse(meta_displacement$pval < 0.05, "*", ""))),
  check.names = FALSE
)

kable(disp_results, 
      caption = "Table 4: Meta-Analysis Coefficients for Displacement",
      align = c('l', rep('c', 6))) %>%
  kable_styling(bootstrap_options = c("striped", "hover"), 
                full_width = FALSE) %>%
  row_spec(0, bold = TRUE, background = "#3498DB", color = "white") %>%
  footnote(general = "Significance: * p<0.05, ** p<0.01, *** p<0.001")
```

