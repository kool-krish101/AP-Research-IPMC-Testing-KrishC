# 9. Hypothesis Testing

```{r hypothesis-test}
cnt_data <- data %>% filter(electrode_material == "CNT Composite")
ag_data <- data %>% filter(electrode_material == "Silver (Ag)")
cu_data <- data %>% filter(electrode_material == "Copper (Cu)")

hypothesis_results <- data.frame(
  Metric = c("Mean Displacement (mm)", "Mean Force (mN)", "Mean Cycles to Failure"),
  CNT = c(
    sprintf("%.2f", mean(cnt_data$displacement_mm)),
    sprintf("%.2f", mean(cnt_data$force_mN)),
    sprintf("%d", round(mean(cnt_data$cycles_to_failure)))
  ),
  Silver = c(
    sprintf("%.2f", mean(ag_data$displacement_mm)),
    sprintf("%.2f", mean(ag_data$force_mN)),
    sprintf("%d", round(mean(ag_data$cycles_to_failure)))
  ),
  Copper = c(
    sprintf("%.2f", mean(cu_data$displacement_mm)),
    sprintf("%.2f", mean(cu_data$force_mN)),
    sprintf("%d", round(mean(cu_data$cycles_to_failure)))
  ),
  `CNT > Ag?` = c(
    ifelse(mean(cnt_data$displacement_mm) > mean(ag_data$displacement_mm), "✓", "✗"),
    ifelse(mean(cnt_data$force_mN) > mean(ag_data$force_mN), "✓", "✗"),
    ifelse(mean(cnt_data$cycles_to_failure) > mean(ag_data$cycles_to_failure), "✓", "✗")
  ),
  `CNT > Cu?` = c(
    ifelse(mean(cnt_data$displacement_mm) > mean(cu_data$displacement_mm), "✓", "✗"),
    ifelse(mean(cnt_data$force_mN) > mean(cu_data$force_mN), "✓", "✗"),
    ifelse(mean(cnt_data$cycles_to_failure) > mean(cu_data$cycles_to_failure), "✓", "✗")
  ),
  check.names = FALSE
)

kable(hypothesis_results, 
      caption = "Table 8: Hypothesis Test - CNT Composite vs Silver and Copper",
      align = c('l', rep('c', 5))) %>%
  kable_styling(bootstrap_options = c("striped", "hover"), 
                full_width = FALSE) %>%
  row_spec(0, bold = TRUE, background = "#E74C3C", color = "white") %>%
  column_spec(1, bold = TRUE, width = "4cm") %>%
  column_spec(2, background = "#FADBD8", bold = TRUE) %>%
  footnote(general = "✓ = CNT superior; ✗ = CNT not superior")

# Determine hypothesis support
disp_support <- mean(cnt_data$displacement_mm) > mean(ag_data$displacement_mm) && 
                mean(cnt_data$displacement_mm) > mean(cu_data$displacement_mm)
dur_support <- mean(cnt_data$cycles_to_failure) > mean(ag_data$cycles_to_failure) && 
               mean(cnt_data$cycles_to_failure) > mean(cu_data$cycles_to_failure)
```

<div class="highlight-box" style="background-color: `r ifelse(disp_support && dur_support, '#D5F4E6', '#FADBD8')`; border-left: 4px solid `r ifelse(disp_support && dur_support, '#27AE60', '#E74C3C')`;">
**HYPOTHESIS VERDICT:** `r ifelse(disp_support && dur_support, "✓ SUPPORTED", "⚠ PARTIALLY SUPPORTED")`

CNT composites demonstrate:
- **Displacement:** `r ifelse(disp_support, "✓ Superior to both Ag and Cu", "✗ Not superior to both")`
- **Durability:** `r ifelse(dur_support, "✓ Superior to both Ag and Cu", "✗ Not superior to both")`

`r if(disp_support && dur_support) "The hypothesis that CNT-based electrodes show greater actuation displacement AND longer durability is SUPPORTED by the data." else "The hypothesis is only partially supported. Review individual comparisons for details."`
</div>

