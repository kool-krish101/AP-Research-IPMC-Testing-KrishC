# 5. Effect Size Calculation

```{r effect-sizes}
# Use Gold as baseline (established standard from Bar-Cohen et al.)
gold_data <- data %>% filter(electrode_material == "Gold (Au)")
gold_mean_disp <- mean(gold_data$displacement_mm, na.rm = TRUE)
gold_sd_disp <- sd(gold_data$displacement_mm, na.rm = TRUE)

data <- data %>%
  mutate(
    hedges_g_displacement = (displacement_mm - gold_mean_disp) / gold_sd_disp,
    sample_size = 200,
    vi_displacement = (displacement_sd^2 / sample_size) + 
                      (hedges_g_displacement^2 / (2 * sample_size))
  )
```

<div class="highlight-box">
**Baseline Reference:** Gold (Au) electrode - Mean displacement: **`r round(gold_mean_disp, 2)` mm** (SD: `r round(gold_sd_disp, 2)`)
